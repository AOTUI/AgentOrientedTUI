{
    "name": "@aotui/system-chat",
    "version": "0.1.1",
    "description": "AOTUI System Chat Application - Agent-Human conversation interface",
    "type": "module",
    "main": "dist/electron/main.mjs",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc && ELECTRON_BUILD_TARGET=main vite build -c vite.electron.config.ts && ELECTRON_BUILD_TARGET=preload vite build -c vite.electron.config.ts",
        "dev": "vite",
        "build:all": "npm run build && npm run build:gui",
        "build:gui": "vite build",
        "preview": "vite preview",
        "test": "vitest",
        "test:run": "vitest run",
        "postinstall": "bash scripts/patch-electron-trpc.sh",
        "electron:dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "npm run build && npm run build:gui && bash scripts/patch-electron-trpc.sh && electron-builder",
        "rebuild": "electron-builder install-app-deps",
        "server:v2": "tsx src/server/start-host-v2.ts"
    },
    "build": {
        "appId": "com.aotui.system-chat",
        "productName": "Agentina",
        "files": [
            "dist/**/*",
            "dist-gui/**/*"
        ],
        "directories": {
            "output": "release"
        },
        "asarUnpack": [
            "**/worker-runtime/**/*"
        ],
        "mac": {
            "icon": "build/icons/mac/icon.icns"
        },
        "dmg": {
            "artifactName": "${productName}.dmg"
        },
        "win": {
            "icon": "build/icons/win/icon.ico"
        },
        "linux": {
            "icon": "build/icon.png"
        }
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.39",
        "@ai-sdk/google": "^3.0.22",
        "@ai-sdk/openai": "^3.0.14",
        "@ai-sdk/react": "^3.0.47",
        "@ai-sdk/xai": "^3.0.48",
        "@aotui/agent-driver-v2": "^0.2.1",
        "@aotui/runtime": "^2.0.0",
        "@aotui/sdk": "^0.2.0",
        "@google/generative-ai": "^0.24.1",
        "@heroui/react": "^2.7.5",
        "@heroui/styles": "3.0.0-beta.5",
        "@larksuiteoapi/node-sdk": "^1.59.0",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@trpc/client": "^10.45.4",
        "@trpc/server": "^10.45.4",
        "@types/sql.js": "^1.4.9",
        "adm-zip": "^0.5.16",
        "ai": "^6.0.77",
        "better-sqlite3": "^12.5.0",
        "clsx": "^2.1.1",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "electron-trpc": "0.4.5",
        "express": "^4.22.1",
        "framer-motion": "^12.29.0",
        "marked": "^17.0.1",
        "mermaid": "^11.14.0",
        "open": "^11.0.0",
        "openai": "^6.15.0",
        "react": "^19.0.0",
        "react-aria-components": "^1.14.0",
        "react-dom": "^19.0.0",
        "sql.js": "^1.13.0",
        "superjson": "^2.2.6",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.0.0",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/adm-zip": "^0.5.7",
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/marked": "^5.0.2",
        "@types/node": "^22.15.21",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^5.1.2",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^41.1.1",
        "electron-builder": "^26.4.0",
        "fast-check": "^4.5.3",
        "happy-dom": "^20.8.9",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.8.3",
        "vite": "^6.0.5",
        "vitest": "^3.2.4",
        "wait-on": "^9.0.4",
        "ws": "^8.18.3"
    },
    "overrides": {
        "@hono/node-server": "^1.19.12",
        "@xmldom/xmldom": "^0.8.12",
        "brace-expansion@1.1.12": "1.1.13",
        "brace-expansion@2.0.2": "2.0.3",
        "express-rate-limit": "^8.3.2",
        "flatted": "^3.4.2",
        "form-data@2.3.3": "2.5.4",
        "hono": "^4.12.10",
        "lodash": "^4.18.0",
        "lodash-es": "^4.18.1",
        "picomatch@4.0.3": "4.0.4",
        "path-to-regexp@0.1.12": "0.1.13",
        "path-to-regexp@8.3.0": "8.4.2",
        "rollup": "^4.60.1",
        "tar": "^7.5.13"
    },
    "pnpm": {
        "overrides": {
            "@hono/node-server": "^1.19.12",
            "@xmldom/xmldom": "^0.8.12",
            "brace-expansion@1.1.12": "1.1.13",
            "brace-expansion@2.0.2": "2.0.3",
            "express-rate-limit": "^8.3.2",
            "flatted": "^3.4.2",
            "form-data@2.3.3": "2.5.4",
            "hono": "^4.12.10",
            "lodash": "^4.18.0",
            "lodash-es": "^4.18.1",
            "picomatch@4.0.3": "4.0.4",
            "path-to-regexp@0.1.12": "0.1.13",
            "path-to-regexp@8.3.0": "8.4.2",
            "rollup": "^4.60.1",
            "tar": "^7.5.13"
        }
    }
}
