{
    "name": "@agentina/aotui-ide",
    "version": "0.1.0",
    "description": "AOTUI IDE app for agent-oriented code browsing, search, editing, and LSP-assisted analysis.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "watch": "tsc --watch",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@aotui/sdk": "^0.1.0",
        "emittery": "^1.2.1",
        "glob": "^10.3.10",
        "lowdb": "^7.0.1",
        "preact": "^10.28.1",
        "vscode-jsonrpc": "^8.2.1",
        "vscode-languageserver-types": "^3.17.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/jest": "^29.0.0",
        "@types/node": "^20.19.30",
        "jest": "^29.0.0",
        "ts-jest": "^29.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-language-server": "^5.1.3",
        "vscode-langservers-extracted": "^4.10.0"
    },
    "optionalDependencies": {
        "pyright": "^1.1.390"
    },
    "keywords": [
        "aotui",
        "agent",
        "tui",
        "ide",
        "lsp"
    ],
    "license": "Apache-2.0",
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist",
        "aoapp.json",
        "README.md",
        "LSP_SETUP.md"
    ]
}
