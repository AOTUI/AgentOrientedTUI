{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@aotui/mobile-ai-native": [
        "../../mobile-ai-native/dist/index.d.ts"
      ],
      "@aotui/mobile-ai-native-react-native": [
        "../../packages/mobile-ai-native-react-native/dist/index.d.ts"
      ]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vitest/globals"]
  },
  "include": ["App.tsx", "src", "test"]
}
