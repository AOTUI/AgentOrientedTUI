{
    "name": "@aotui/sdk",
    "version": "0.2.0",
    "description": "AOTUI Developer SDK - Build Agent-Oriented TUI Apps with Preact",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "test": "vitest",
        "test:run": "vitest --run",
        "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "preact": "^10.0.0"
    },
    "dependencies": {
        "@aotui/runtime": "^2.0.0",
        "@preact/signals": "^2.5.1",
        "linkedom": "^0.18.9"
    },
    "devDependencies": {
        "@testing-library/preact": "^3.2.4",
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^8.49.0",
        "@typescript-eslint/parser": "^8.49.0",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "jsdom": "^27.0.1",
        "preact": "^10.29.1",
        "preact-render-to-string": "^6.6.4",
        "prettier": "^3.7.4",
        "typescript": "^5.3.0",
        "vitest": "^3.2.4"
    },
    "overrides": {
        "ajv": "^6.14.0",
        "brace-expansion@1.1.12": "1.1.13",
        "brace-expansion@2.0.2": "2.0.3",
        "flatted": "^3.4.2",
        "happy-dom": "^20.8.9",
        "minimatch@3.1.2": "3.1.4",
        "minimatch@9.0.5": "9.0.7",
        "picomatch@4.0.3": "4.0.4",
        "preact": "^10.29.1",
        "rollup": "^4.60.1"
    },
    "pnpm": {
        "overrides": {
            "ajv": "^6.14.0",
            "brace-expansion@1.1.12": "1.1.13",
            "brace-expansion@2.0.2": "2.0.3",
            "flatted": "^3.4.2",
            "happy-dom": "^20.8.9",
            "minimatch@3.1.2": "3.1.4",
            "minimatch@9.0.5": "9.0.7",
            "picomatch@4.0.3": "4.0.4",
            "preact": "^10.29.1",
            "rollup": "^4.60.1"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "aotui",
        "tui",
        "preact",
        "agent",
        "llm"
    ],
    "license": "Apache-2.0",
    "publishConfig": {
        "access": "public"
    }
}
