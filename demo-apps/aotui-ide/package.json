{
    "name": "@agentina/aotui-ide",
    "version": "0.1.2",
    "description": "AOTUI IDE app for agent-oriented code browsing, search, editing, and LSP-assisted analysis.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc && node ../../scripts/generate-aoapp.mjs .",
        "watch": "tsc --watch",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@aotui/sdk": "file:../../sdk",
        "emittery": "^1.2.1",
        "glob": "^10.3.10",
        "lowdb": "^7.0.1",
        "preact": "^10.29.1",
        "vscode-jsonrpc": "^8.2.1",
        "vscode-languageserver-types": "^3.17.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/jest": "^29.0.0",
        "@types/node": "^20.19.30",
        "jest": "^29.0.0",
        "ts-jest": "^29.4.9",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-language-server": "^5.1.3",
        "vscode-langservers-extracted": "^4.10.0"
    },
    "overrides": {
        "brace-expansion@1.1.12": "1.1.13",
        "brace-expansion@2.0.2": "2.0.3",
        "handlebars": "^4.7.9",
        "happy-dom": "^20.8.9",
        "minimatch@3.1.2": "3.1.4",
        "minimatch@9.0.5": "9.0.7",
        "picomatch@2.3.1": "2.3.2",
        "preact": "^10.29.1"
    },
    "optionalDependencies": {
        "pyright": "^1.1.390"
    },
    "pnpm": {
        "overrides": {
            "brace-expansion@1.1.12": "1.1.13",
            "brace-expansion@2.0.2": "2.0.3",
            "handlebars": "^4.7.9",
            "happy-dom": "^20.8.9",
            "minimatch@3.1.2": "3.1.4",
            "minimatch@9.0.5": "9.0.7",
            "picomatch@2.3.1": "2.3.2",
            "preact": "^10.29.1"
        }
    },
    "keywords": [
        "aotui",
        "agent",
        "tui",
        "ide",
        "lsp"
    ],
    "license": "Apache-2.0",
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist",
        "aoapp.json",
        "README.md",
        "LSP_SETUP.md"
    ]
