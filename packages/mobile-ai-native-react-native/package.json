{
  "name": "@aotui/mobile-ai-native-react-native",
  "version": "0.1.0-alpha.0",
  "description": "React Native / Expo host adapter for the mobile AI-native runtime.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "test": "vitest",
    "test:run": "vitest --run",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@aotui/mobile-ai-native": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "aotui",
    "mobile",
    "react-native",
    "expo",
    "agent-native"
  ],
  "publishConfig": {
    "access": "public"
  }
}
